generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  PARTIAL_SUCCESS
  FAILED
}

model Job {
  id          String    @id @default(uuid())
  status      JobStatus @default(QUEUED)
  totalRows   Int
  processed   Int       @default(0)
  failed      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  results   Result[]
  rowErrors RowError[]

  @@map("jobs")
}

model Result {
  id           String   @id @default(uuid())
  jobId        String
  rowIndex     Int
  name         String
  company      String
  industry     String
  city         String
  openingLine  String
  email        String   @db.Text
  subjectLine1 String
  subjectLine2 String
  processedAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("results")
}

model RowError {
  id       String   @id @default(uuid())
  jobId    String
  rowIndex Int
  name     String?
  error    String
  message  String
  failedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("row_errors")
}