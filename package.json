{
   "name": "moxsend-engine",
   "version": "1.0.0",
   "description": "Moxsend CSV Processing Engine — async personalised outreach generation",
   "main": "dist/server.js",
   "scripts": {
      "build": "tsc",
      "start": "node dist/server.js",
      "dev": "tsx watch src/server.ts",
      "db:generate": "prisma generate",
      "db:migrate": "prisma migrate dev",
      "db:migrate:prod": "prisma migrate deploy",
      "db:studio": "prisma studio",
      "db:push": "prisma db push",
      "lint": "eslint src --ext .ts",
      "lint:fix": "eslint src --ext .ts --fix",
      "format": "prettier --write \"src/**/*.ts\"",
      "test": "jest --runInBand",
      "test:watch": "jest --watch",
      "test:coverage": "jest --coverage"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "dependencies": {
      "@prisma/client": "^5.22.0",
      "amqplib": "^1.0.3",
      "cors": "^2.8.6",
      "csv-parse": "^6.2.1",
      "dotenv": "^17.4.2",
      "express": "^4.22.1",
      "express-async-errors": "^3.1.1",
      "helmet": "^8.1.0",
      "morgan": "^1.10.1",
      "multer": "^2.1.1",
      "p-limit": "^7.3.0",
      "uuid": "^14.0.0",
      "winston": "^3.19.0",
      "zod": "^4.3.6"
   },
   "devDependencies": {
      "@types/amqplib": "^0.10.8",
      "@types/cors": "^2.8.19",
      "@types/express": "^5.0.6",
      "@types/jest": "^30.0.0",
      "@types/morgan": "^1.9.10",
      "@types/multer": "^2.1.0",
      "@types/node": "^25.6.0",
      "@types/pg": "^8.20.0",
      "@types/supertest": "^7.2.0",
      "@types/uuid": "^10.0.0",
      "@typescript-eslint/eslint-plugin": "^8.59.0",
      "@typescript-eslint/parser": "^8.59.0",
      "eslint": "^10.2.1",
      "jest": "^30.3.0",
      "prettier": "^3.8.3",
      "prisma": "^5.22.0",
      "supertest": "^7.2.2",
      "ts-jest": "^29.4.9",
      "tsx": "^4.21.0",
      "typescript": "^6.0.3"
   }
}
